<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_tp_offcuts" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.tp.offcuts</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='stock']" position="after">
                <app
                    data-string="Offcut Manager"
                    string="Offcut Manager"
                    name="tp_offcuts_nesting"
                    logo="/tp_offcuts_nesting/static/description/settings_icon.svg"
                    groups="stock.group_stock_manager"
                >
                    <block title="General" name="tp_offcuts_settings_container">
                        <setting id="tp_waste_account_setting" help="Account used for offcut waste postings.">
                            <field name="tp_waste_account_id"/>
                        </setting>
                        <setting id="tp_waste_journal_setting" help="Journal used for offcut waste accounting entries.">
                            <field name="tp_waste_journal_id"/>
                        </setting>
                        <setting id="tp_offcut_sold_bin_setting" help="Internal BIN location used when offcuts are marked as sold.">
                            <field name="tp_offcut_sold_bin_location_id"/>
                        </setting>
                        <setting id="tp_offcut_sold_cleanup_days_setting" help="Delete sold offcuts after this many days in the sold BIN.">
                            <field name="tp_offcut_sold_cleanup_days"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
