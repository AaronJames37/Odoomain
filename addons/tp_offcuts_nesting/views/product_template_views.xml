<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_tp_material" model="ir.ui.view">
        <field name="name">product.template.form.tp.material</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Material">
                    <group>
                        <group>
                            <field name="tp_material_type"/>
                            <field name="tp_thickness_option"/>
                            <field name="tp_colour"/>
                        </group>
                        <group>
                            <field name="tp_finish"/>
                            <field name="tp_protective_film"/>
                            <field name="tp_brand_supplier"/>
                        </group>
                    </group>
                    <group string="Sheet Stock Source (SKU-based)">
                        <group>
                            <field name="tp_sheet_width_mm"/>
                            <field name="tp_sheet_height_mm"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
