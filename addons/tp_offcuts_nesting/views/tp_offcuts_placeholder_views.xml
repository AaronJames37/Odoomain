<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tp_offcuts_placeholder_tree" model="ir.ui.view">
        <field name="name">tp.offcuts.placeholder.tree</field>
        <field name="model">tp.offcuts.placeholder</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_tp_offcuts_placeholder_form" model="ir.ui.view">
        <field name="name">tp.offcuts.placeholder.form</field>
        <field name="model">tp.offcuts.placeholder</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tp_offcuts_placeholder" model="ir.actions.act_window">
        <field name="name">Operations</field>
        <field name="res_model">tp.offcuts.placeholder</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
