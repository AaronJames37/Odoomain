<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tp_offcut_valuation_event_tree" model="ir.ui.view">
        <field name="name">tp.offcut.valuation.event.list</field>
        <field name="model">tp.offcut.valuation.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="event_type"/>
                <field name="offcut_id"/>
                <field name="parent_offcut_id"/>
                <field name="input_value"/>
                <field name="offcut_value"/>
                <field name="waste_value"/>
                <field name="remainder_value"/>
                <field name="is_conserved"/>
                <field name="conservation_delta"/>
            </list>
        </field>
    </record>

    <record id="view_tp_offcut_valuation_event_form" model="ir.ui.view">
        <field name="name">tp.offcut.valuation.event.form</field>
        <field name="model">tp.offcut.valuation.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="event_type"/>
                        <field name="currency_id"/>
                        <field name="mo_id"/>
                    </group>
                    <group>
                        <field name="offcut_id"/>
                        <field name="parent_offcut_id"/>
                        <field name="parent_lot_id"/>
                    </group>
                    <group string="Values">
                        <field name="input_area_mm2"/>
                        <field name="input_value"/>
                        <field name="offcut_area_mm2"/>
                        <field name="offcut_value"/>
                        <field name="waste_area_mm2"/>
                        <field name="waste_value"/>
                        <field name="remainder_area_mm2"/>
                        <field name="remainder_value"/>
                        <field name="is_conserved"/>
                        <field name="conservation_delta"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tp_offcut_valuation_event" model="ir.actions.act_window">
        <field name="name">Valuation Events</field>
        <field name="res_model">tp.offcut.valuation.event</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
