<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_lot_form_tp_dimensions" model="ir.ui.view">
        <field name="name">stock.lot.form.tp.dimensions</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="tp_width_mm"/>
                <field name="tp_height_mm"/>
                <field name="tp_is_offcut"/>
                <field name="tp_lot_type" readonly="1"/>
                <field name="tp_parent_lot_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_lot_tree_tp_dimensions" model="ir.ui.view">
        <field name="name">stock.lot.list.tp.dimensions</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='product_id']" position="after">
                <field name="tp_lot_type"/>
                <field name="tp_width_mm" optional="show"/>
                <field name="tp_height_mm" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_lot_search_tp_offcuts" model="ir.ui.view">
        <field name="name">stock.lot.search.tp.offcuts</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.search_product_lot_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='create_date']" position="after">
                <filter string="Offcuts" name="tp_offcuts_only" domain="[('tp_lot_type', '=', 'offcut')]"/>
                <filter string="Full Sheets" name="tp_full_sheets_only" domain="[('tp_lot_type', '=', 'sheet')]"/>
            </xpath>
            <xpath expr="//search/group" position="inside">
                <filter name="group_by_tp_lot_type" string="Lot Type" domain="[]" context="{'group_by': 'tp_lot_type'}"/>
            </xpath>
            <xpath expr="//search" position="inside">
                <searchpanel>
                    <field name="tp_lot_type" string="Offcuts" enable_counters="1"/>
                </searchpanel>
            </xpath>
        </field>
    </record>
</odoo>
