<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tp_sheet_format_tree" model="ir.ui.view">
        <field name="name">tp.sheet.format.list</field>
        <field name="model">tp.sheet.format</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="width_mm"/>
                <field name="height_mm"/>
                <field name="area_mm2"/>
                <field name="landed_cost"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tp_sheet_format_form" model="ir.ui.view">
        <field name="name">tp.sheet.format.form</field>
        <field name="model">tp.sheet.format</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Core">
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Dimensions">
                            <field name="width_mm"/>
                            <field name="height_mm"/>
                            <field name="area_mm2" readonly="1"/>
                        </group>
                    </group>
                    <group string="Material Identity">
                        <field name="tp_material_type"/>
                        <field name="tp_thickness_mm"/>
                        <field name="tp_colour"/>
                        <field name="tp_finish"/>
                        <field name="tp_protective_film"/>
                        <field name="tp_brand_supplier"/>
                    </group>
                    <group string="Valuation Basis">
                        <field name="currency_id"/>
                        <field name="landed_cost"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tp_sheet_format_search" model="ir.ui.view">
        <field name="name">tp.sheet.format.search</field>
        <field name="model">tp.sheet.format</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="product_id"/>
                <field name="tp_material_type"/>
                <field name="tp_thickness_mm"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <group>
                    <filter string="By Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="By Material" name="group_material" context="{'group_by': 'tp_material_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tp_sheet_format" model="ir.actions.act_window">
        <field name="name">Sheet Formats</field>
        <field name="res_model">tp.sheet.format</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tp_sheet_format_search"/>
    </record>
</odoo>
