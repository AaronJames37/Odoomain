<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tp_nesting_source_map_tree" model="ir.ui.view">
        <field name="name">tp.nesting.source.map.list</field>
        <field name="model">tp.nesting.source.map</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="active"/>
                <field name="name"/>
                <field name="demand_product_id"/>
                <field name="source_product_id" domain="[('tp_sheet_width_mm', '>', 0), ('tp_sheet_height_mm', '>', 0)]"/>
                <field name="source_lot_id"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_tp_nesting_source_map_form" model="ir.ui.view">
        <field name="name">tp.nesting.source.map.form</field>
        <field name="model">tp.nesting.source.map</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="demand_product_id"/>
                            <field name="source_product_id" domain="[('tp_sheet_width_mm', '>', 0), ('tp_sheet_height_mm', '>', 0)]"/>
                            <field name="source_lot_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tp_nesting_source_map_search" model="ir.ui.view">
        <field name="name">tp.nesting.source.map.search</field>
        <field name="model">tp.nesting.source.map</field>
        <field name="arch" type="xml">
            <search>
                <field name="demand_product_id"/>
                <field name="source_product_id"/>
                <field name="source_lot_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <group>
                    <filter string="Demand Product" name="grp_demand" context="{'group_by': 'demand_product_id'}"/>
                    <filter string="Source Product" name="grp_source_product" context="{'group_by': 'source_product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tp_nesting_source_map" model="ir.actions.act_window">
        <field name="name">Nesting Source Mapping</field>
        <field name="res_model">tp.nesting.source.map</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tp_nesting_source_map_search"/>
    </record>
</odoo>
