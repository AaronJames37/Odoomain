<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tp_nesting_run_tree" model="ir.ui.view">
        <field name="name">tp.nesting.run.list</field>
        <field name="model">tp.nesting.run</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="mo_id"/>
                <field name="job_id"/>
                <field name="state"/>
                <field name="engine_mode"/>
                <field name="kerf_mm"/>
                <field name="rotation_mode"/>
                <field name="search_nodes"/>
                <field name="search_ms"/>
                <field name="started_at"/>
                <field name="finished_at"/>
            </list>
        </field>
    </record>

    <record id="view_tp_nesting_run_form" model="ir.ui.view">
        <field name="name">tp.nesting.run.form</field>
        <field name="model">tp.nesting.run</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="mo_id"/>
                            <field name="job_id"/>
                            <field name="state"/>
                            <field name="engine_mode"/>
                        </group>
                        <group>
                            <field name="kerf_mm"/>
                            <field name="rotation_mode"/>
                            <field name="started_at"/>
                            <field name="finished_at"/>
                            <field name="outputs_materialized"/>
                            <field name="outputs_materialized_at"/>
                        </group>
                    </group>
                    <group string="Telemetry">
                        <field name="search_nodes"/>
                        <field name="search_ms"/>
                        <field name="waste_area_mm2_total"/>
                        <field name="offcut_utilization_pct"/>
                        <field name="full_sheet_count"/>
                        <field name="score"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <group string="Allocations">
                        <field name="allocation_ids" readonly="1">
                            <list>
                                <field name="source_type"/>
                                <field name="source_offcut_id"/>
                                <field name="source_sheet_format_id"/>
                                <field name="source_lot_id"/>
                                <field name="source_bin_key"/>
                                <field name="cut_width_mm"/>
                                <field name="cut_height_mm"/>
                                <field name="placed_x_mm"/>
                                <field name="placed_y_mm"/>
                                <field name="cut_quantity"/>
                                <field name="rotation_applied"/>
                                <field name="allocated_area_mm2"/>
                                <field name="status"/>
                            </list>
                        </field>
                    </group>
                    <group string="Consumed Material Lots">
                        <field name="consumed_lot_ids" readonly="1">
                            <list>
                                <field name="lot_id"/>
                                <field name="source_type"/>
                                <field name="allocation_count"/>
                            </list>
                        </field>
                    </group>
                    <group string="Produced Panels">
                        <field name="produced_panel_ids" readonly="1">
                            <list>
                                <field name="allocation_id"/>
                                <field name="source_lot_id"/>
                                <field name="width_mm"/>
                                <field name="height_mm"/>
                                <field name="quantity"/>
                            </list>
                        </field>
                    </group>
                    <group string="Produced Offcuts">
                        <field name="produced_offcut_ids" readonly="1" domain="[('planned_kind', '=', 'offcut')]">
                            <list>
                                <field name="state"/>
                                <field name="planned_kind"/>
                                <field name="offcut_id"/>
                                <field name="lot_id"/>
                                <field name="width_mm"/>
                                <field name="height_mm"/>
                                <field name="source_type"/>
                            </list>
                        </field>
                    </group>
                    <group string="Nesting Visual">
                        <field name="nesting_svg" widget="html" readonly="1"/>
                    </group>
                    <group string="Optimizer Rationale">
                        <field name="selected_order_name"/>
                        <field name="scoring_preset"/>
                        <field name="candidate_plan_count"/>
                        <field name="rejected_plan_count"/>
                        <field name="score_breakdown_json" widget="text"/>
                        <field name="debug_artifact_json" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tp_nesting_run_search" model="ir.ui.view">
        <field name="name">tp.nesting.run.search</field>
        <field name="model">tp.nesting.run</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="mo_id"/>
                <field name="state"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <group>
                    <filter string="By MO" name="group_mo" context="{'group_by': 'mo_id'}"/>
                    <filter string="By State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tp_nesting_run" model="ir.actions.act_window">
        <field name="name">Nesting Runs</field>
        <field name="res_model">tp.nesting.run</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tp_nesting_run_search"/>
    </record>
</odoo>
