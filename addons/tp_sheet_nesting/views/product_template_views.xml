<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_tp_nesting_source_button" model="ir.ui.view">
        <field name="name">product.template.form.tp.nesting.source.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_tp_nesting_source_maps"
                    string="Nesting Sources"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-random"
                    groups="mrp.group_mrp_manager"
                >
                    <field name="tp_nesting_source_map_count" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
